# Twitch247 Configuration
# Copy to /opt/twitch247/config/config.env and fill in values

# Twitch RTMP credentials
TWITCH_STREAM_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_CHANNEL=yourchannel

# YouTube source channel (streams tab)
YOUTUBE_CHANNEL_URL=https://youtube.com/@galitubereal/streams

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Position save interval in seconds (default: 15)
SAVE_INTERVAL=15

# YouTube sync interval in seconds (default: 3600 = 1 hour)
SYNC_INTERVAL=3600

# Only keep the latest N YouTube streams in the local queue
YOUTUBE_SYNC_LIMIT=15

# Seek tolerance on restart in seconds (HLS segmentation)
SEEK_TOLERANCE=5

# FFmpeg video bitrate for Twitch
VIDEO_BITRATE=6000k
MAXRATE=6000k
BUFSIZE=12000k
AUDIO_BITRATE=160k

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Discord login protection for the dashboard
# Create a Discord OAuth2 application, then set the exact redirect URI you registered there.
# Example redirect: https://dashboard.example.com/oauth/callback
DASHBOARD_SECRET_KEY=replace-with-random-secret
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_OAUTH_REDIRECT_URI=https://dashboard.example.com/oauth/callback
# Comma or space separated Discord user IDs allowed to view the dashboard
DASHBOARD_ALLOWED_DISCORD_USER_IDS=123456789012345678,234567890123456789

# Optional Discord webhook notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Paths (defaults for /opt/twitch247 installation)
APP_ROOT=/opt/twitch247
DB_PATH=/opt/twitch247/database/twitch247.db
LOG_DIR=/opt/twitch247/logs
